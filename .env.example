# Army Bank — приклад конфігурації. Скопіюйте в .env і заповніть.

# PostgreSQL (основний варіант)
DATABASE_URL=postgresql://user:password@localhost:5432/army_bank

# Або залиште порожнім для SQLite (файл database/army_bank.db)
# DATABASE_URL=

# Секрет для сесій та токенів
SECRET_KEY=your-secret-key-min-32-chars

# Час життя токена (години)
TOKEN_TTL_HOURS=24

# Режим відлагодження (1 або 0)
DEBUG=1

# Базовий шлях на сайті (наприклад /bank для munister.com.ua/bank)
# BASE_PATH=/bank
