# Скопіюйте у репозиторій як .github/workflows/deploy-munister-marketing.yml
# і зробіть commit з машини/акаунта з правом workflow (або додайте файл у веб-інтерфейсі GitHub).
#
# Secrets (Settings → Secrets → Actions):
#   MUNISTER_SSH_HOST
#   MUNISTER_SSH_USER
#   MUNISTER_SSH_PRIVATE_KEY
#   MUNISTER_REMOTE_ARMY_ADMIN   (шлях з / на кінці, напр. /var/www/.../army-admin/)
#   MUNISTER_REMOTE_ARMY_BANK

name: Deploy munister marketing (army-admin, army-bank)

on:
  push:
    branches: [main]
    paths:
      - 'marketing/**'
      - '.github/workflows/deploy-munister-marketing.yml'
  workflow_dispatch:

jobs:
  rsync:
    if: ${{ secrets.MUNISTER_SSH_HOST != '' }}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Rsync static sites
        env:
          SSH_PRIVATE_KEY: ${{ secrets.MUNISTER_SSH_PRIVATE_KEY }}
          HOST: ${{ secrets.MUNISTER_SSH_HOST }}
          USER: ${{ secrets.MUNISTER_SSH_USER }}
          PATH_ADMIN: ${{ secrets.MUNISTER_REMOTE_ARMY_ADMIN }}
          PATH_BANK: ${{ secrets.MUNISTER_REMOTE_ARMY_BANK }}
        run: |
          set -euo pipefail
          mkdir -p ~/.ssh
          printf '%s\n' "$SSH_PRIVATE_KEY" > ~/.ssh/id_deploy
          chmod 600 ~/.ssh/id_deploy
          ssh-keyscan -H "$HOST" >> ~/.ssh/known_hosts 2>/dev/null || true
          SSH_OPTS="-i ~/.ssh/id_deploy -o StrictHostKeyChecking=accept-new"
          rsync -avz --delete -e "ssh $SSH_OPTS" marketing/munister-army-admin/ "${USER}@${HOST}:${PATH_ADMIN}"
          rsync -avz --delete -e "ssh $SSH_OPTS" marketing/munister-army-bank/ "${USER}@${HOST}:${PATH_BANK}"
